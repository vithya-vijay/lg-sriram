<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Logo & Footer Settings</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('../partials/admin-nav', { activePage: 'settings' }) %>

  <main class="admin-main">
    <div class="admin-page-header">
      <h1>🎨 Logo & Footer Settings</h1>
    </div>

    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <!-- Logo + Shop Name -->
    <div class="admin-card admin-card-narrow">
      <h2>Shop Logo & Name</h2>

      <% if (settings.logo_path) { %>
        <div class="current-logo-preview">
          <p class="field-hint">Current logo:</p>
          <img src="<%= settings.logo_path %>" alt="Current logo" class="logo-preview-img">
        </div>
      <% } %>

      <form action="/admin/settings/logo" method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <label for="shop_name">Shop Name</label>
          <input type="text" id="shop_name" name="shop_name" value="<%= settings.shop_name || '' %>" placeholder="Your Shop Name">
        </div>

        <div class="form-group">
          <label for="logo">Upload New Logo</label>
          <input type="file" id="logo" name="logo" accept=".png,.jpg,.jpeg,.svg,.webp">
          <span class="field-hint">PNG, JPG, SVG, or WEBP. Max 2MB. Leave blank to keep current logo.</span>
        </div>

        <button type="submit" class="btn btn-primary">Save Logo & Name</button>
      </form>
    </div>

    <!-- Categories -->
    <div class="admin-card">
      <h2>Feedback Form Categories</h2>
      <p class="subtitle">These appear as the Category dropdown on the customer feedback form.</p>

      <form action="/admin/settings/categories/add" method="POST" class="inline-form">
        <input type="text" name="name" placeholder="Category name (e.g. Refrigerators)" required>
        <input type="number" name="display_order" placeholder="Order" min="0" style="width:80px;">
        <button type="submit" class="btn btn-primary btn-sm">Add Category</button>
      </form>

      <% if (categories.length === 0) { %>
        <p class="empty-state">No categories added yet.</p>
      <% } else { %>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr><th>Order</th><th>Name</th><th>Action</th></tr>
            </thead>
            <tbody>
              <% categories.forEach(cat => { %>
                <tr>
                  <td><%= cat.display_order %></td>
                  <td><%= cat.name %></td>
                  <td>
                    <form action="/admin/settings/categories/<%= cat.id %>/delete" method="POST" onsubmit="return confirm('Remove this category? Existing feedback entries that used it will keep their data but show no category.');">
                      <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Footer Links -->
    <div class="admin-card">
      <h2>Footer Links</h2>
      <p class="subtitle">These links appear in the footer of the customer feedback page.</p>

      <form action="/admin/settings/footer-links/add" method="POST" class="inline-form footer-link-form">
        <input type="text" name="label" placeholder="Link label (e.g. Privacy Policy)" required>
        <input type="url" name="url" placeholder="https://example.com/privacy" required>
        <input type="number" name="display_order" placeholder="Order" min="0" style="width:80px;">
        <button type="submit" class="btn btn-primary btn-sm">Add Link</button>
      </form>

      <% if (footerLinks.length === 0) { %>
        <p class="empty-state">No footer links added yet.</p>
      <% } else { %>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr><th>Order</th><th>Label</th><th>URL</th><th>Action</th></tr>
            </thead>
            <tbody>
              <% footerLinks.forEach(link => { %>
                <tr>
                  <td><%= link.display_order %></td>
                  <td><%= link.label %></td>
                  <td><a href="<%= link.url %>" target="_blank"><%= link.url %></a></td>
                  <td>
                    <form action="/admin/settings/footer-links/<%= link.id %>/delete" method="POST" onsubmit="return confirm('Remove this footer link?');">
                      <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </main>
</body>
</html>
